ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different models/versions of Python,
#   they may want to keep the Pipfile.lock local and run pipenv lock --keep-outdated.
#Pipfile.lock

# poetry
#   Poetry uses pyproject.toml to manage dependencies. lock file should be tracked,
#   but we can ignore poetry's local cache/config if needed.

# pdm
#   PDM stores project-local configuration in .pdm.toml
#   and instals dependencies in __pypackages__

# Environments
.env
.env.*
.venv
venv/
ENV/
env/
*env/

